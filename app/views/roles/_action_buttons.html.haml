- is_used = false

- if is_used
  = link_to "Show usage (#{@usage_counts[role.id]})".html_safe, usage_role_path(role), class: 'btn btn-default'
- else
  .btn.btn-default.disabled Not used

= link_to edit_role_path(role), class: 'btn btn-info' do
  %i.glyphicon.glyphicon-edit
  Edit

- if is_used
  .btn.btn-danger.disabled{ title:'Keyword is used and cannot be deleted.' }
    %i.glyphicon.glyphicon-trash
    Delete
- else
  = link_to role_path(role, redirect_to: request.fullpath), method: :delete, data: { |
    confirm: 'The role will be deleted. Do you want to proceed?' }, |
    class: 'btn btn-danger' do
    %i.glyphicon.glyphicon-trash
    Delete
