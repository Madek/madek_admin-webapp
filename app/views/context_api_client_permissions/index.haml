.page-header
  %h1
    API Client Permissions for
    %span #{@context.id}
    Context
  %small= link_to "&larr; Go back to the context".html_safe, context_path(@context)

.row
  .col-xs-12
    .panel.panel-default
      .panel-body
        .btn-group
          = link_to new_context_context_api_client_permission_path(@context),
              class: 'btn btn-default' do
            %i.glyphicon.glyphicon-plus
            Create API Client Permission

.row
  .col-xs-12
    %table.table.table-striped
      %thead
        %tr
          %th API Client
          %th Can view?
          %th
      %tbody
        = render partial: 'api_client_permission', collection: @api_client_permissions, as: :api_client_permission
