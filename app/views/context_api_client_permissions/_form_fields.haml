= f.hidden_field :api_client_id
.form-group
  .col-xs-2
    = f.label :context_id, class: 'control-label'
  .col-xs-6
    = f.text_field :context_id, disabled: true, class: 'form-control', value: @context.id
.form-group
  .col-xs-2
    = f.label :api_client_id, class: 'control-label'
  .col-xs-6
    = f.text_field :api_client_id, value: f.object.api_client&.login, class: 'form-control', disabled: true
  .col-xs-2
    = link_to api_clients_path(add_to_context_id: @context.id, permission_id: @permission.id, is_persisted: f.object.persisted?), class: 'btn btn-warning' do
      Choose API Client
- if f.object.api_client_id.present?
  .form-group
    .col-xs-2
      %label.control-label Permissions
    .col-xs-6
      .checkbox
        %label
          = f.check_box :view
          Can view?
  .form-group
    .col-xs-offset-2.col-xs-3
      = button_tag type: 'submit', class: 'btn btn-success' do
        %span.glyphicon.glyphicon-ok
        Save
      = link_to 'Go back', context_context_api_client_permissions_path(@context), class: 'btn btn-link'
