.page-header
  %h1
    New Group Permission
    %small Context: #{@context}

.row
  .col-xs-12
    = form_for [@context, @permission],
        method: :post,
        as: :context_group_permission,
        url: context_context_group_permissions_path(@context, reset_context_permission_params: true),
        html: { class: 'form-horizontal', role: 'form' } do |f|
      = render partial: 'form_fields', locals: { f: f }
