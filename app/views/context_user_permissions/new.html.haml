.page-header
  %h1
    New User Permission
    %small Context: #{@context}

.row
  .col-xs-12
    = form_for [@context, @permission],
        method: :post,
        as: :context_user_permission,
        url: context_context_user_permissions_path(@context),
        html: { class: 'form-horizontal', role: 'form' } do |f|
      = render partial: 'form_fields', locals: { f: f }
